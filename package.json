{
  "name": "teleport-contest",
  "version": "1.0.0",
  "description": "The Teleport Coding Challenge — Port NetHack C to JavaScript",
  "type": "module",
  "scripts": {
    "score": "bash frozen/score.sh",
    "score:strict": "node tools/strict-score.mjs sessions/",
    "debug:failures": "node tools/analyze-failures.mjs sessions/",
    "check:submission": "node tools/check-submission.mjs",
    "check:final": "npm run check:submission && npm run score:strict",
    "c2js:probe": "node tools/c2js/build-engine.mjs --probe",
    "c2js:clean": "rm -rf .cache/c2js",
    "c2js:prepare": "node tools/c2js/build-engine.mjs --prepare-source",
    "c2js:compile-smoke": "node tools/c2js/build-engine.mjs --compile-smoke",
    "c2js:compile-core": "node tools/c2js/build-engine.mjs --compile-core",
    "c2js:compile-lua": "node tools/c2js/build-engine.mjs --compile-lua",
    "c2js:compile-port": "node tools/c2js/build-engine.mjs --compile-port",
    "c2js:link": "node tools/c2js/build-engine.mjs --link-engine",
    "c2js:format": "node tools/c2js/format.mjs",
    "c2js:update": "node tools/c2js/build-engine.mjs --update-generated",
    "trace:generate": "node tools/generate-local-traces.mjs",
    "trace:generate:smoke": "node tools/generate-local-traces.mjs --tier smoke --build --force --score",
    "trace:generate:expanded": "node tools/generate-local-traces.mjs --tier default --build --force",
    "trace:generate:stress": "node tools/generate-local-traces.mjs --tier stress --build --force --out .cache/local-traces-raw-stress",
    "trace:generate:edge": "node tools/generate-local-traces.mjs --tier edge --build --force --out .cache/local-traces-edge --feature-report .cache/local-traces-edge-features.json",
    "trace:generate:risk": "node tools/generate-local-traces.mjs --tier risk --build --force --out .cache/local-traces-risk",
    "trace:generate:forensic": "node tools/generate-local-traces.mjs --tier forensic --build --force --out .cache/local-traces-forensic --feature-report .cache/local-traces-forensic-features.json",
    "trace:score": "node tools/analyze-failures.mjs .cache/local-traces",
    "trace:strict": "node tools/strict-score.mjs .cache/local-traces",
    "trace:check:competition": "SESSION_REPLAY_TIMEOUT_MS=30000 SESSION_REPLAY_JOBS=4 node tools/check-traces.mjs --mode competition .cache/local-traces",
    "trace:check:paranoid": "SESSION_REPLAY_TIMEOUT_MS=30000 SESSION_REPLAY_JOBS=4 node tools/check-traces.mjs --mode paranoid .cache/local-traces",
    "trace:check:edge:competition": "SESSION_REPLAY_TIMEOUT_MS=30000 SESSION_REPLAY_JOBS=4 node tools/check-traces.mjs --mode competition .cache/local-traces-edge",
    "trace:check:edge:paranoid": "SESSION_REPLAY_TIMEOUT_MS=30000 SESSION_REPLAY_JOBS=4 node tools/check-traces.mjs --mode paranoid .cache/local-traces-edge",
    "trace:check:risk:competition": "SESSION_REPLAY_TIMEOUT_MS=30000 SESSION_REPLAY_JOBS=4 node tools/check-traces.mjs --mode competition .cache/local-traces-risk",
    "trace:check:risk:paranoid": "SESSION_REPLAY_TIMEOUT_MS=30000 SESSION_REPLAY_JOBS=4 node tools/check-traces.mjs --mode paranoid .cache/local-traces-risk",
    "trace:check:forensic:competition": "SESSION_REPLAY_TIMEOUT_MS=30000 SESSION_REPLAY_JOBS=4 node tools/check-traces.mjs --mode competition .cache/local-traces-forensic",
    "trace:check:forensic:paranoid": "SESSION_REPLAY_TIMEOUT_MS=30000 SESSION_REPLAY_JOBS=4 node tools/check-traces.mjs --mode paranoid .cache/local-traces-forensic",
    "trace:check:stress:competition": "SESSION_REPLAY_TIMEOUT_MS=30000 SESSION_REPLAY_JOBS=4 node tools/check-traces.mjs --mode competition .cache/local-traces-raw-stress",
    "trace:check:stress:paranoid": "SESSION_REPLAY_TIMEOUT_MS=30000 SESSION_REPLAY_JOBS=4 node tools/check-traces.mjs --mode paranoid .cache/local-traces-raw-stress",
    "trace:raw:stress": "node tools/raw-screen-diff.mjs --limit=1 .cache/local-traces-raw-stress",
    "trace:minimize": "node tools/minimize-trace.mjs",
    "trace:verify-public": "node scripts/verify-rerecord.mjs",
    "play": "python3 -m http.server 8000"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "prettier": "3.8.3"
  }
}
